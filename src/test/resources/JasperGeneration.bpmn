          <zeebe:input source="=customerInfo" target="parameters" />
          <zeebe:input source="={ &#34;storageDefinition&#34;: &#34;URL&#34;, &#34;content&#34;: &#34;https://github.com/camunda-community-hub/camunda-8-connector-jasper/raw/main/src/test/resources/ProcessInstanceReport.jrxml&#34;}" target="jasperReport" />
          <zeebe:input source="=&#34;ProcessInstanceReport.pdf&#34;" target="destinationFileName" />
          <zeebe:input source="={ &#34;type&#34;: &#34;CAMUNDA&#34;}" target="destinationJsonStorageDefinition" />
