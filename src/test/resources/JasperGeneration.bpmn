    <bpmn:textAnnotation id="TextAnnotation_1t0ymhs">
      <bpmn:text>The loan is accepted or rejected randomly 50/50%)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0sh47ky">
      <bpmn:text>LoanApplicationReport.jrxml</bpmn:text>
    </bpmn:textAnnotation>
