    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_0iwqxyw" name="get Loan information">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="LoanValidation" />
        <zeebe:ioMapping>
          <zeebe:output source="=loanAcceptanceComment" target="loanAcceptanceComment" />
          <zeebe:output source="=if count(loanAccepted) &#62; 0 then loanAccepted[1] else &#34;rejected&#34;&#10;" target="loanAccepted" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1mzux68</bpmn:incoming>
      <bpmn:outgoing>Flow_1ehkjog</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:scriptTask id="Activity_0crispm" name="Customer info">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#34;customerName&#34;: &#34;Camunda&#34;, &#34;customerAddress&#34;: &#34;453 Ocean view&#34;, &#10; &#34;customerCity&#34;:&#34;San Francisco&#34;}" resultVariable="customerInfo" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_08vqime</bpmn:incoming>
      <bpmn:outgoing>Flow_1mzux68</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_122rmzu" sourceRef="Gateway_14420v4" targetRef="Activity_1odcw2f">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=loanAccepted = "accepted"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0mtpy6f" sourceRef="Activity_1odcw2f" targetRef="Activity_1sai7gf" />
    <bpmn:sequenceFlow id="Flow_1d6dp54" sourceRef="Gateway_14420v4" targetRef="Activity_1sai7gf" />
    <bpmn:serviceTask id="Activity_1sai7gf" name="Loan Application Report">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="c-jasper-function" />
        <zeebe:ioMapping>
          <zeebe:input source="={&#34;customerInfo&#34;: customerInfo,&#10; &#34;creditScore&#34;: creditScore,&#10; &#34;loanInfo&#34;: loanInfo,&#10; &#34;loanAccepted&#34;:loanAccepted,&#10;&#34;loanAcceptanceComment&#34;: loanAcceptanceComment}" target="data" />
          <zeebe:input source="={ &#34;storageDefinition&#34;: &#34;URL&#34;, &#34;content&#34;: &#34;https://github.com/camunda-community-hub/camunda-8-connector-jasper/raw/main/src/test/resources/ProcessInstanceReport.jrxml&#34;}" target="jasperReportURL" />
          <zeebe:input source="=&#34;ProcessInstanceReport.pdf&#34;" target="destinationFileName" />
          <zeebe:input source="={ &#34;type&#34;: &#34;CAMUNDA&#34;}" target="destinationJsonStorageDefinition" />
          <zeebe:input source="={ &#34;storageDefinition&#34;: &#34;FOLDER:c:/dev/intellij/community/connector/camunda-8-connector-jasper/src/test/resources&#34;, &#10;  &#34;content&#34;: &#34;LoanApplicationReport.jrxml&#34;}" target="jasperReport" />
          <zeebe:input source="=&#34;PDF&#34;" target="formatExport" />
          <zeebe:input source="=true" target="includeProcessHistory" />
          <zeebe:output source="= result.destinationFile" target="LoanApplicationReport" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0mtpy6f</bpmn:incoming>
      <bpmn:incoming>Flow_1d6dp54</bpmn:incoming>
      <bpmn:outgoing>Flow_1rto3qv</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Activity_1odcw2f" name="General Loan">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#34;loanId&#34;: floor(random number() * 9000) + 1000,&#10;&#34;startDate&#34;: now(),&#10;&#34;amount&#34;: floor(random number() * 4000) + 12000}" resultVariable="loanInfo" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_122rmzu</bpmn:incoming>
      <bpmn:outgoing>Flow_0mtpy6f</bpmn:outgoing>
    </bpmn:scriptTask>
