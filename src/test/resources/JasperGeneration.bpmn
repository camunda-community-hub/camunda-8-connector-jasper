    <bpmn:scriptTask id="Activity_0crispm" name="Customer info">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#34;customerName&#34;: &#34;Camunda&#34;, &#34;customerAddress&#34;: &#34;453 Ocean view&#34;, &#10; &#34;customerCity&#34;:&#34;San Francisco&#34;}" resultVariable="customerInfo" />
