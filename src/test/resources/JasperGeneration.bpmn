    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_03jegks</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Activity_0jgchuk" name="Get credit">
      <bpmn:extensionElements>
        <zeebe:script expression="=floor(random number() * 251) + 600" resultVariable="creditScore" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03jegks</bpmn:incoming>
      <bpmn:outgoing>Flow_08vqime</bpmn:outgoing>
    </bpmn:scriptTask>
