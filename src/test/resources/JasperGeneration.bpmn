  <bpmn:process id="Process_JasperReport" name="JasperReport" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_03jegks</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:scriptTask id="Activity_0jgchuk" name="Get credit">
      <bpmn:extensionElements>
        <zeebe:script expression="=floor(random number() * 251) + 600" resultVariable="creditScore" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03jegks</bpmn:incoming>
      <bpmn:outgoing>Flow_08vqime</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:exclusiveGateway id="Gateway_14420v4" default="Flow_1d6dp54">
      <bpmn:incoming>Flow_1ehkjog</bpmn:incoming>
      <bpmn:incoming>Flow_0n5mvxg</bpmn:incoming>
      <bpmn:outgoing>Flow_122rmzu</bpmn:outgoing>
      <bpmn:outgoing>Flow_1d6dp54</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_0iwqxyw" name="get Loan information">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="LoanValidation" />
        <zeebe:ioMapping>
          <zeebe:output source="=loanAcceptanceComment" target="loanAcceptanceComment" />
          <zeebe:output source="=if count(loanAccepted) &#62; 0 then loanAccepted[1] else &#34;rejected&#34;&#10;" target="loanAccepted" />
          <zeebe:output source="=jasperReport" target="jasperReport" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1mzux68</bpmn:incoming>
      <bpmn:outgoing>Flow_1ehkjog</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:scriptTask id="Activity_0crispm" name="Customer info">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#34;customerName&#34;: &#34;Camunda&#34;, &#34;customerAddress&#34;: &#34;453 Ocean view&#34;, &#10; &#34;customerCity&#34;:&#34;San Francisco&#34;}" resultVariable="customerInfo" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_08vqime</bpmn:incoming>
      <bpmn:outgoing>Flow_1mzux68</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_1odcw2f" name="General Loan">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#34;loanId&#34;: floor(random number() * 9000) + 1000,&#10;&#34;startDate&#34;: now(),&#10; &#34;loanType&#34;: &#34;Personal&#34;,&#10; &#34;rate&#34;: 3.54,&#10; &#34;numberOfMonths&#34;: 15*12,&#10; &#34;amountMontlyRembursement&#34;: 2730.12,&#10;&#34;amount&#34;: floor(random number() * 4000) + 12000}" resultVariable="loanInfo" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_122rmzu</bpmn:incoming>
      <bpmn:outgoing>Flow_0mtpy6f</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:subProcess id="Activity_12s7z2r" triggeredByEvent="true">
      <bpmn:startEvent id="Event_1pmvp1r" name="1h">
        <bpmn:outgoing>Flow_0judoqm</bpmn:outgoing>
        <bpmn:timerEventDefinition id="TimerEventDefinition_0it66g9">
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1H</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:startEvent>
      <bpmn:endEvent id="Event_04w8oab">
        <bpmn:incoming>Flow_0judoqm</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0judoqm" sourceRef="Event_1pmvp1r" targetRef="Event_04w8oab" />
    </bpmn:subProcess>
    <bpmn:endEvent id="Event_1tht7w2">
      <bpmn:incoming>Flow_0zp24ui</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_1coxw5u" name="Review">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="JasperResultForm" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_17ysk8a</bpmn:incoming>
      <bpmn:outgoing>Flow_0zp24ui</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Activity_1ousf0m" name="Loan Application Report" zeebe:modelerTemplate="io.camunda.connector.jasper.JasperFunction" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="c-jasper-function" />
        <zeebe:ioMapping>
          <zeebe:input source="false" target="destinationJsonStorageDefinition_optional" />
          <zeebe:input source="={ &#10;  &#34;storageDefinition&#34;: &#34;URL&#34;, &#10;  &#34;content&#34;: &#34;https://github.com/camunda-community-hub/camunda-8-connector-jasper/raw/main/src/test/resources/LoanApplicationReport.jrxml&#34;&#10;}&#10;" target="jasperReport" />
          <zeebe:input source="={&#34;customerInfo&#34;: customerInfo,&#10; &#34;creditScore&#34;: creditScore,&#10; &#34;loanInfo&#34;: loanInfo,&#10; &#34;loanAccepted&#34;:loanAccepted,&#10;&#34;loanAcceptanceComment&#34;: loanAcceptanceComment,&#10; &#34;bankInfo&#34;: {&#34;phoneNumber&#34;: &#34;672 233 1323&#34;}}" target="data" />
          <zeebe:input source="PDF" target="formatExport" />
          <zeebe:input source="false" target="includeContext" />
          <zeebe:input source="false" target="includeProcessHistory" />
          <zeebe:input source="=&#34;ProcessInstanceReport.pdf&#34;" target="destinationFileName" />
          <zeebe:input source="={ &#34;type&#34;: &#34;CAMUNDA&#34;}" target="destinationJsonStorageDefinition" />
          <zeebe:output source="= result.destinationFile" target="LoanApplicationReport" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
          <zeebe:header key="errorExpression" value="if is defined(error) then bpmnError(error.code, error.message) else null" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0mtpy6f</bpmn:incoming>
      <bpmn:incoming>Flow_1d6dp54</bpmn:incoming>
      <bpmn:outgoing>Flow_1rto3qv</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Activity_0q9v0a3" name="Accepted">
      <bpmn:extensionElements>
        <zeebe:script expression="=12" resultVariable="result" />
        <zeebe:ioMapping>
          <zeebe:output source="=&#34;The loan is accepted by default - too long &#34;" target="loanAcceptanceComment" />
          <zeebe:output source="=if random number() &#62; 0.5 then &#34;accepted&#34; else &#34;rejected&#34;" target="loanAccepted" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_156pk4a</bpmn:incoming>
      <bpmn:outgoing>Flow_0n5mvxg</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Activity_17o1wor" name="Jasper Report PI" zeebe:modelerTemplate="io.camunda.connector.jasper.JasperFunction" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="c-jasper-function" />
        <zeebe:ioMapping>
          <zeebe:input source="true" target="destinationJsonStorageDefinition_optional" />
          <zeebe:input source="=&#10;{ &#10;  &#34;storageDefinition&#34;: &#34;FOLDER:C:/dev/intellij/community/connector/camunda-8-connector-jasper/src/test/resources&#34;, &#10;  &#34;content&#34;: &#34;ProcessInstanceReport.jrxml&#34;}" target="jasperReport" />
          <zeebe:input source="={&#34;customerInfo&#34;: customerInfo,&#10; &#34;creditScore&#34;: creditScore,&#10; &#34;loanInfo&#34;: loanInfo,&#10; &#34;loanAccepted&#34;:loanAccepted,&#10;&#34;loanAcceptanceComment&#34;: loanAcceptanceComment,&#10; &#34;bankInfo&#34;: {&#34;phoneNumber&#34;: &#34;672 233 1323&#34;}&#10;}" target="data" />
          <zeebe:input source="PDF" target="formatExport" />
          <zeebe:input source="true" target="includeContext" />
          <zeebe:input source="true" target="includeProcessHistory" />
          <zeebe:input source="=&#34;ProcessInstanceReport.pdf&#34;" target="destinationFileName" />
          <zeebe:input source="={ &#34;type&#34;: &#34;CAMUNDA&#34;}" target="destinationJsonStorageDefinition" />
          <zeebe:output source="= result.destinationFile" target="processInstanceReport" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
          <zeebe:header key="errorExpression" value="if is defined(error) then bpmnError(error.code, error.message) else null" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1rto3qv</bpmn:incoming>
      <bpmn:outgoing>Flow_17ysk8a</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="Event_126470m" name="30s" attachedToRef="Activity_0iwqxyw">
      <bpmn:outgoing>Flow_156pk4a</bpmn:outgoing>
