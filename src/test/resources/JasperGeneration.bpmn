          <zeebe:input source="=&#34;PDF&#34;" target="formatExport" />
          <zeebe:output source="= result.destinationFile" target="processInstanceReportFileStorage" />
          <zeebe:output source="= [result.destinationFile.camundaReference]" target="processInstanceReportHistory" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="result" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1sugaee</bpmn:incoming>
      <bpmn:outgoing>Flow_1rto3qv</bpmn:outgoing>
